{
  "F9S Program skeleton": {
    "prefix": "program",
    "body": [
      "PROGRAM ${1:name}",
      "\t$0",
      "END PROGRAM ${1:name}"
    ],
    "description": "Basic F9S program structure"
  },

  "INTEGER declaration": {
    "prefix": "int",
    "body": "INTEGER ${1:var} := ${2:0}",
    "description": "Declare an INTEGER variable"
  },

  "REAL declaration": {
    "prefix": "real",
    "body": "REAL ${1:var} := ${2:0.0}",
    "description": "Declare a REAL variable"
  },

  "LOGICAL declaration": {
    "prefix": "logical",
    "body": "LOGICAL ${1:flag} := ${2:.TRUE.}",
    "description": "Declare a LOGICAL variable"
  },

  "STRING declaration": {
    "prefix": "string",
    "body": "STRING ${1:var} := \"${2:text}\"",
    "description": "Declare a STRING variable"
  },

  "CHARACTER declaration": {
    "prefix": "char",
    "body": "CHARACTER ${1:var} := \"${2:x}\"",
    "description": "Declare a CHARACTER variable"
  },

  "COMPLEX declaration": {
    "prefix": "complex",
    "body": "COMPLEX ${1:var} := (${2:0.0},${3:0.0})",
    "description": "Declare a COMPLEX variable"
  },

  "PRINT star": {
    "prefix": "print",
    "body": "PRINT *, ${1:expr}",
    "description": "PRINT *, expression"
  },

  "PRINT variable": {
    "prefix": "printv",
    "body": "PRINT ${1:var}",
    "description": "PRINT variable"
  },

  "ASSIGN statement": {
    "prefix": "assign",
    "body": "ASSIGN ${1:var}, ${2:value}",
    "description": "ASSIGN variable, value"
  },

  "PRINT string literal": {
    "prefix": "prints",
    "body": "PRINT *, \"${1:Hello, World!}\"",
    "description": "Print a string literal"
  },

  "Hello World": {
    "prefix": "hello",
    "body": [
      "PROGRAM hello",
      "\tPRINT *, \"Hello, World!\"",
      "END PROGRAM hello"
    ],
    "description": "Hello World program"
  },

  "Full typed example": {
    "prefix": "f9sfull",
    "body": [
      "PROGRAM ${1:example}",
      "\tINTEGER n := ${2:42}",
      "\tREAL pi := 3.14159",
      "\tLOGICAL flag := .TRUE.",
      "\tPRINT *, n",
      "\tPRINT *, pi",
      "\tPRINT *, flag",
      "END PROGRAM ${1:example}"
    ],
    "description": "Full typed F9S example"
  },

  "IF THEN block": {
    "prefix": "if",
    "body": [
      "IF (${1:condition}) THEN",
      "\t$0",
      "END IF"
    ],
    "description": "IF (condition) THEN ... END IF"
  },

  "IF THEN ELSE block": {
    "prefix": "ifelse",
    "body": [
      "IF (${1:condition}) THEN",
      "\t${2:! true branch}",
      "ELSE",
      "\t${3:! false branch}",
      "END IF"
    ],
    "description": "IF (condition) THEN ... ELSE ... END IF"
  },

  "IF THEN ELSE IF block": {
    "prefix": "ifelseif",
    "body": [
      "IF (${1:condition}) THEN",
      "\t${2:! first branch}",
      "ELSE IF (${3:condition2}) THEN",
      "\t${4:! second branch}",
      "ELSE",
      "\t${5:! default branch}",
      "END IF"
    ],
    "description": "IF / ELSE IF / ELSE / END IF chain"
  },

  "DO loop": {
    "prefix": "do",
    "body": [
      "DO ${1:i} = ${2:1}, ${3:n}",
      "\t$0",
      "END DO"
    ],
    "description": "DO i = start, end ... END DO"
  },

  "DO loop with step": {
    "prefix": "dostep",
    "body": [
      "DO ${1:i} = ${2:1}, ${3:n}, ${4:1}",
      "\t$0",
      "END DO"
    ],
    "description": "DO i = start, end, step ... END DO"
  },

  "STOP statement": {
    "prefix": "stop",
    "body": "STOP",
    "description": "Terminate program execution"
  }
}
